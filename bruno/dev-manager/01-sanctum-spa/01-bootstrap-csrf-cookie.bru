meta {
  name: 01 - bootstrap csrf cookie
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/sanctum/csrf-cookie
  body: none
  auth: none
}

headers {
  Accept: application/json
  Origin: {{spaOrigin}}
}

docs {
  # Sanctum SPA bootstrap

  1) Hits the csrf cookie endpoint so Laravel sets `XSRF-TOKEN` and `laravel_session`.
  2) Bruno saves both cookies automatically (folder-level cookie jar).
  3) The post-response script captures the *decoded* `XSRF-TOKEN` raw value into
     the env var `xsrfRaw` so subsequent requests can send it back via
     `X-XSRF-TOKEN` without re-encoding.

  Expected: 204 No Content, XSRF-TOKEN cookie present.
}

script:post-response {
  const setCookieHeader = res.headers["set-cookie"];
  if (setCookieHeader) {
    const cookies = Array.isArray(setCookieHeader)
      ? setCookieHeader
      : [setCookieHeader];
    const xsrfRawMatch = cookies
      .map((c) => c.match(/XSRF-TOKEN=([^;]+)/i))
      .find((m) => m);
    if (xsrfRawMatch && xsrfRawMatch[1]) {
      bru.setEnvVar("xsrfRaw", decodeURIComponent(xsrfRawMatch[1]));
    }
  }
}
