meta {
  name: 04 - logout (session)
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/api/auth/logout
  body: none
  auth: none
}

headers {
  Accept: application/json
  Origin: {{spaOrigin}}
}

docs {
  # Logout invalidates the session cookie and regenerates a fresh one.

  After this request the previously stored `laravel_session` cookie is
  invalidated. A subsequent /api/user without re-logging-in must return 401.

  Expected: 204 No Content.
}
