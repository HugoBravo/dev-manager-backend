meta {
  name: 02 - login (session)
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

headers {
  Accept: application/json
  Content-Type: application/json
  Origin: {{spaOrigin}}
  X-XSRF-TOKEN: {{xsrfRaw}}
}

body:json {
  {
    "email": "{{email}}",
    "password": "123",
    "device_name": "bruno-spa"
  }
}

script:post-response {
  // Persist user id for follow-up assertions.
  try {
    const body = res.getBody();
    if (body && body.data && body.data.id) {
      bru.setEnvVar("userId", String(body.data.id));
    }
  } catch (e) {
    // ignore — body might be empty for non-2xx responses
  }
}

docs {
  # Login against the SPA cookie session endpoint.
  
  Relies on:
  - Request 01 having set the `XSRF-TOKEN` cookie.
  - `Origin` matching an entry in `SANCTUM_STATEFUL_DOMAINS`.
  - The `X-XSRF-TOKEN` header echoing the decoded cookie value.
  
  Expected: 200 OK with `{ data: { id, name, email, email_verified_at } }`
  and a rotated `laravel_session` cookie. After this response you are
  authenticated via the `web` guard and the `/api/user` endpoint will work
  with just cookies.
}
