meta {
  name: 03 - get me (cookie)
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/api/user
  body: none
  auth: none
}

headers {
  Accept: application/json
  Origin: {{spaOrigin}}
}

docs {
  # Authenticated /api/user using only the session cookie.

  If you ran 01 + 02 successfully, Bruno should be sending
  `Cookie: laravel_session=...` automatically. The Sanctum guard will
  authenticate via the `web` driver bound to the session.

  Expected: 200 OK with `{ data: { id, name, email } }`.
}
