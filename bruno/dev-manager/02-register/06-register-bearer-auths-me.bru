meta {
  name: 06 - register bearer authenticates GET /api/user
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/api/user
  body: none
  auth: bearer
}

auth:bearer {
  token: {{registerBearerToken}}
}

headers {
  Accept: application/json
}

docs {
  # Integration: the token issued by `01-register-success` works
  # immediately as `Authorization: Bearer <token>` against `GET /api/user`.

  Prereq: run `01-register-success` first so `registerBearerToken` is set.

  Expected: 200 with the same `{ data: { id, name, email } }` envelope.
}