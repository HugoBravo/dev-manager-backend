meta {
  name: 02 - register missing name (422)
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/auth/register
  body: json
  auth: none
}

headers {
  Accept: application/json
  Content-Type: application/json
}

body:json {
  {
    "email": "{{registerEmail}}",
    "password": "{{registerPassword}}",
    "password_confirmation": "{{registerPassword}}"
  }
}

docs {
  # Negative: missing `name` triggers FormRequest validation.

  Rule: `RegisterRequest::rules()['name']` is `required|string|max:120`.

  Expected: 422 with `errors.name`.
}