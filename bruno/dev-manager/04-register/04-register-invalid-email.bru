meta {
  name: 04 - register invalid email (422)
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/api/auth/register
  body: json
  auth: none
}

headers {
  Accept: application/json
  Content-Type: application/json
  Origin: {{spaOrigin}}
  X-XSRF-TOKEN: {{xsrfRaw}}
}

body:json {
  {
    "name": "{{registerName}}",
    "email": "not-an-email",
    "password": "{{registerPassword}}",
    "password_confirmation": "{{registerPassword}}"
  }
}

docs {
  # Negative: invalid email format triggers the `email` rule.

  Rule: `RegisterRequest::rules()['email']` is `required|email|max:180|unique:users,email`.

  Expected: 422 with `errors.email`.
}