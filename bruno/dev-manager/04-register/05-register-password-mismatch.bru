meta {
  name: 05 - register password mismatch (422)
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/api/auth/register
  body: json
  auth: none
}

headers {
  Accept: application/json
  Content-Type: application/json
  Origin: {{spaOrigin}}
  X-XSRF-TOKEN: {{xsrfRaw}}
}

body:json {
  {
    "name": "{{registerName}}",
    "email": "{{registerEmail}}",
    "password": "{{registerPassword}}",
    "password_confirmation": "different-password"
  }
}

docs {
  # Negative: password without `confirmed` triggers the `password` rule.

  Rule: `RegisterRequest::rules()['password']` is `required|string|min:8|confirmed`.

  Expected: 422 with `errors.password`.
}