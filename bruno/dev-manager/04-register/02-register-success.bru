meta {
  name: 02 - register success
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/auth/register
  body: json
  auth: none
}

headers {
  Accept: application/json
  Content-Type: application/json
  Origin: {{spaOrigin}}
  X-XSRF-TOKEN: {{xsrfRaw}}
}

body:json {
  {
    "name": "{{registerName}}",
    "email": "{{registerEmail}}",
    "password": "{{registerPassword}}",
    "password_confirmation": "{{registerPassword}}",
    "device_name": "bruno-spa"
  }
}

docs {
  # Happy-path self-registration.

  Backend behavior (`auth-register-2026`):
  - Creates the user with `email_verified_at = now()`.
  - Hashes the password via the model cast (`'password' => 'hashed'`).
  - Auto-logs the user in via `Auth::guard('web')->login()` and
    regenerates the session id.
  - Returns 201 Created with the `UserResource` envelope
    `{ data: { id, name, email, email_verified_at } }`.

  Bruno also captures the resulting user id into the `userId` env var
  so the integration request (07) can reuse it.

  Expected: 201, `data.id`, `data.email`, `data.email_verified_at`
  present; `laravel_session` cookie rotated.

  Pitfall: if `registerEmail` already exists in the DB, this will
  return 422 with `errors.email`. Change the env var or seed a fresh
  user before retrying.
}

script:post-response {
  try {
    const body = res.getBody();
    if (body && body.data && body.data.id) {
      bru.setEnvVar("userId", String(body.data.id));
    }
  } catch (e) {
    // ignore — body might be empty for non-2xx responses
  }
}