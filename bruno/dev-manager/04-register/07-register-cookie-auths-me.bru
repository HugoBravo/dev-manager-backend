meta {
  name: 07 - register session authenticates GET /api/user
  type: http
  seq: 7
}

get {
  url: {{baseUrl}}/api/user
  body: none
  auth: none
}

headers {
  Accept: application/json
  Origin: {{spaOrigin}}
}

docs {
  # Integration: after a successful register, the session cookie lets
  # GET /api/user succeed without sending any Bearer token.

  Prereq: run `01-bootstrap-csrf-cookie` and `02-register-success` first
  so the cookie jar carries a valid `laravel_session` for the new user.

  Expected: 200 OK with the same `{ data: { id, name, email } }` envelope.
  If you see 401, the session cookie was dropped between requests —
  re-run 01 and 02 in the same Bruno tab.
}