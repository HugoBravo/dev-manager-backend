meta {
  name: 01 - bootstrap csrf cookie (register)
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/sanctum/csrf-cookie
  body: none
  auth: none
}

headers {
  Accept: application/json
  Origin: {{spaOrigin}}
}

docs {
  # Bootstrap XSRF + session cookies for the register flow.

  Same as the SPA flow's `01-bootstrap-csrf-cookie.bru` — runs the
  Sanctum CSRF cookie endpoint and decodes the `XSRF-TOKEN` value into
  the `xsrfRaw` env var so subsequent POSTs can send it back via
  `X-XSRF-TOKEN`. Required before `02-register-success`.

  Expected: 204 No Content, XSRF-TOKEN cookie set.
}

script:post-response {
  const setCookieHeader = res.headers["set-cookie"];
  if (setCookieHeader) {
    const cookies = Array.isArray(setCookieHeader)
      ? setCookieHeader
      : [setCookieHeader];
    const xsrfRawMatch = cookies
      .map((c) => c.match(/XSRF-TOKEN=([^;]+)/i))
      .find((m) => m);
    if (xsrfRawMatch && xsrfRawMatch[1]) {
      bru.setEnvVar("xsrfRaw", decodeURIComponent(xsrfRawMatch[1]));
    }
  }
}