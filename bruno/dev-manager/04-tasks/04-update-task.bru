  token: {{bearerToken}}
}

headers {
  Accept: application/json
  Content-Type: application/json
}

body:json {
  {
    "name": "Refactor checkout (rev 2)",
    "status": "done"
  }
}

docs {
  # Partial update on a task.

  Expected: 200, `data.task` shape per TaskResource.
}
