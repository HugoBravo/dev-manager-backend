meta {
  name: 02 - get me (bearer)
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/user
  body: none
  auth: bearer
}

auth:bearer {
  token: {{personalToken}}
}

headers {
  Accept: application/json
  Origin: {{spaOrigin}}
}

docs {
  # Authenticated /api/user using a Sanctum bearer token.

  No Origin-based cookie trick is required: this works for arbitrary
  clients as long as `Authorization: Bearer <token>` is sent. The token
  guard is `sanctum` (driver=sanctum, provider=users).

  Expected: 200 OK with the same `{ data: { id, name, email } }` payload.
}
