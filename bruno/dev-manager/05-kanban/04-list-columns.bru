meta {
  name: 04 - list columns
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/api/v1/projects/{{projectId}}/tasks/{{taskId}}/kanban/boards/{{boardId}}/columns
  body: none
  auth: bearer
}

auth:bearer {
  token: {{bearerToken}}
}

headers {
  Accept: application/json
}

docs {
  # List columns of a board (paginated 25/page; archived columns hidden).

  Expected: 200, `data[]` shape per ColumnResource.

  Pitfall: the literal `columns/reorder` and `columns/{column}/move`
  routes are registered BEFORE the apiResource's `{column}` wildcard,
  otherwise Laravel would match `/reorder` against `{column}`.
}

script:post-response {
  try {
    const body = res.getBody();
    if (body && body.data && body.data[0] && body.data[0].data) {
      bru.setEnvVar("columnId", String(body.data[0].data.id));
    }
  } catch (e) {
    // ignore
  }
}
