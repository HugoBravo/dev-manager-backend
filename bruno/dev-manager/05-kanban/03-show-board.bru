meta {
  name: 03 - show board
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/api/v1/projects/{{projectId}}/tasks/{{taskId}}/kanban/boards/{{boardId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{bearerToken}}
}

headers {
  Accept: application/json
}

docs {
  # Show one board. 404 on cross-task (board not under this task) or
  # cross-owner. The chain-resolve guard in
  # `ResolvesKanbanChain::ensureBoardBelongsToTask` enforces this.

  Expected: 200, BoardResource with `task_id` + embedded `task`.
}
