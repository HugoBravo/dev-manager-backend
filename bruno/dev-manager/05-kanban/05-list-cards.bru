meta {
  name: 05 - list cards
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/api/v1/projects/{{projectId}}/tasks/{{taskId}}/kanban/boards/{{boardId}}/columns/{{columnId}}/cards
  body: none
  auth: bearer
}

auth:bearer {
  token: {{bearerToken}}
}

headers {
  Accept: application/json
}

docs {
  # List cards of a column (paginated 25/page).
  # `?archived=1` includes archived cards (default hides them) — that's
  # the CARD archive flag, orthogonal to the project's `?include_archived`.

  Expected: 200, `data[]` shape per CardResource.
}

script:post-response {
  try {
    const body = res.getBody();
    if (body && body.data && body.data[0] && body.data[0].data) {
      bru.setEnvVar("cardId", String(body.data[0].data.id));
    }
  } catch (e) {
    // ignore
  }
}
