meta {
  name: 01 - list task boards
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/v1/projects/{{projectId}}/tasks/{{taskId}}/kanban/boards
  body: none
  auth: bearer
}

auth:bearer {
  token: {{bearerToken}}
}

headers {
  Accept: application/json
}

docs {
  # List boards under a task (paginated 25/page; archived boards hidden).

  Backend behavior (`kanban-per-task`, commit 8):
  - Boards are now scoped to `{task}`, not `{project}`.
  - `?include_archived=1` threads through the new task layer
    (spec REQ-MIGRATION-2).

  Expected: 200, `data[]` shape per BoardResource (with embedded `task`).
}

script:post-response {
  try {
    const body = res.getBody();
    if (body && body.data && body.data[0] && body.data[0].data) {
      bru.setEnvVar("boardId", String(body.data[0].data.id));
    }
  } catch (e) {
    // ignore
  }
}
