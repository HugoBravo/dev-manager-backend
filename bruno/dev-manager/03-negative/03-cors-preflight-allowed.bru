meta {
  name: 03 - CORS preflight allowed origin
  type: http
  seq: 3
}

options {
  url: {{baseUrl}}/api/user
  body: none
  auth: none
}

headers {
  Accept: application/json
  Origin: http://localhost:4200
  Access-Control-Request-Method: GET
  Access-Control-Request-Headers: Authorization
}

docs {
  # CORS preflight from an allowed origin.

  The expected response headers:
  - `Access-Control-Allow-Origin: http://localhost:4200` (echo of Origin).
  - `Access-Control-Allow-Headers: Authorization` (since the API requires Bearer).
  - `Access-Control-Allow-Credentials` MUST NOT be set (bearer mode).

  If `Access-Control-Allow-Origin` echoes `http://localhost:4200` and
  `Authorization` is in `Access-Control-Allow-Headers`, the API is ready
  to serve the SPA.

  Expected: 200/204 with the CORS headers above.
}