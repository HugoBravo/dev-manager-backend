meta {
  name: 01 - login bad password (422)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

headers {
  Accept: application/json
  Content-Type: application/json
}

body:json {
  {
    "email": "{{email}}",
    "password": "wrong-password"
  }
}

docs {
  # Negative: invalid credentials return 422 with `errors.email`.

  Rule: `Auth::guard('web')->attempt` fails → `SessionController::store`
  throws `ValidationException::withMessages(['email' => [__('auth.failed')]])`.

  Expected: 422 with `errors.email`.
}