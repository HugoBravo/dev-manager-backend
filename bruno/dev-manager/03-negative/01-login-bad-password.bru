meta {
  name: 01 - login bad password
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

headers {
  Accept: application/json
  Content-Type: application/json
  Origin: {{spaOrigin}}
  X-XSRF-TOKEN: {{xsrfRaw}}
}

body:json {
  {
    "email": "{{email}}",
    "password": "wrong-password"
  }
}

docs {
  # Negative: bad credentials must return 422.

  Our implementation aborts with `Response::HTTP_UNPROCESSABLE_ENTITY`
  and the message "invalid_credentials". The CSRF middleware must still
  pass (we still need csrf cookie + X-XSRF-TOKEN).

  Expected: 422 Unprocessable Entity.
}
