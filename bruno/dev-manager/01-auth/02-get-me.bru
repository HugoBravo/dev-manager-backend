meta {
  name: 02 - get me (bearer)
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/user
  body: none
  auth: bearer
}

auth:bearer {
  token: {{bearerToken}}
}

headers {
  Accept: application/json
}

docs {
  # Authenticated `GET /api/user` using a bearer token.

  Prereq: run `01-login` first to populate `bearerToken`.

  Expected: 200 with `{ data: { id, name, email } }` matching the user
  whose token was issued.
}